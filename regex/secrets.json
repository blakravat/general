{
    "version": "1.1.0",
    "secrets": [
        {
            "name": "AWS Access Key ID",
            "regex": "(?:A3T[A-Z0-9]|AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}",
            "flags": "g"
        },
        {
            "name": "AWS Secret Access Key",
            "regex": "(?:aws[_\\-\\s]?secret[_\\-\\s]?access[_\\-\\s]?key)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9/+]{40})",
            "flags": "gi"
        },
        {
            "name": "AWS Session Token",
            "regex": "(?:aws[_\\-\\s]?session[_\\-\\s]?token)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9/+=]{100,})",
            "flags": "gi"
        },
        {
            "name": "GCP / Firebase API Key",
            "regex": "AIza[0-9A-Za-z\\-_]{35}",
            "flags": "g"
        },
        {
            "name": "GCP Service Account Key",
            "regex": "\\\"type\\\"\\s*:\\s*\\\"service_account\\\"",
            "flags": "g"
        },
        {
            "name": "Azure Storage Connection String",
            "regex": "DefaultEndpointsProtocol=https?;AccountName=[^;]+;AccountKey=([A-Za-z0-9+/=]{88})",
            "flags": "gi"
        },
        {
            "name": "Azure Client Secret",
            "regex": "(?:azure[_\\-\\s]?client[_\\-\\s]?secret)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9~._\\-]{34,})",
            "flags": "gi"
        },
        {
            "name": "GitHub Personal Access Token",
            "regex": "ghp_[A-Za-z0-9]{36}",
            "flags": "g"
        },
        {
            "name": "GitHub OAuth Token",
            "regex": "gho_[A-Za-z0-9]{36}",
            "flags": "g"
        },
        {
            "name": "GitHub App User / Server Token",
            "regex": "(?:ghu|ghs)_[A-Za-z0-9]{36}",
            "flags": "g"
        },
        {
            "name": "GitHub Refresh Token",
            "regex": "ghr_[A-Za-z0-9]{76}",
            "flags": "g"
        },
        {
            "name": "GitLab Personal Access Token",
            "regex": "glpat-[A-Za-z0-9\\-_]{20}",
            "flags": "g"
        },
        {
            "name": "GitLab Runner Token",
            "regex": "glrt-[A-Za-z0-9\\-_]{20}",
            "flags": "g"
        },
        {
            "name": "Stripe Live Secret Key",
            "regex": "sk_live_[0-9A-Za-z]{24,}",
            "flags": "g"
        },
        {
            "name": "Stripe Live Restricted Key",
            "regex": "rk_live_[0-9A-Za-z]{24,}",
            "flags": "g"
        },
        {
            "name": "Stripe Live Publishable Key",
            "regex": "pk_live_[0-9A-Za-z]{24,}",
            "flags": "g"
        },
        {
            "name": "Stripe Test Secret Key",
            "regex": "sk_test_[0-9A-Za-z]{24,}",
            "flags": "g"
        },
        {
            "name": "PayPal / Braintree Production Access Token",
            "regex": "access_token\\$production\\$[0-9a-z]{16}\\$[0-9a-f]{32}",
            "flags": "g"
        },
        {
            "name": "Square Access Token",
            "regex": "EAAAl[A-Za-z0-9_\\-]{60}",
            "flags": "g"
        },
        {
            "name": "Slack Bot Token",
            "regex": "xoxb-[0-9]{10,13}-[0-9]{10,13}-[A-Za-z0-9]{24}",
            "flags": "g"
        },
        {
            "name": "Slack User Token",
            "regex": "xoxp-[0-9]{10,13}-[0-9]{10,13}-[0-9]{10,13}-[A-Za-z0-9]{32}",
            "flags": "g"
        },
        {
            "name": "Slack App-Level Token",
            "regex": "xapp-[0-9]-[A-Za-z0-9]{10,}-[0-9]{13}-[A-Za-z0-9]{64}",
            "flags": "g"
        },
        {
            "name": "Slack Webhook URL",
            "regex": "https://hooks\\.slack\\.com/services/T[A-Za-z0-9_]{8,}/B[A-Za-z0-9_]{8,}/[A-Za-z0-9_]{24,}",
            "flags": "g"
        },
        {
            "name": "Discord Bot Token",
            "regex": "[MN][A-Za-z0-9]{23}\\.[A-Za-z0-9_\\-]{6}\\.[A-Za-z0-9_\\-]{27,}",
            "flags": "g"
        },
        {
            "name": "Discord Webhook URL",
            "regex": "https://(?:ptb\\.|canary\\.)?discord(?:app)?\\.com/api/webhooks/[0-9]{17,19}/[A-Za-z0-9_\\-]{68,}",
            "flags": "g"
        },
        {
            "name": "Telegram Bot Token",
            "regex": "[0-9]{8,10}:AA[A-Za-z0-9_\\-]{33}",
            "flags": "g"
        },
        {
            "name": "Twilio Account SID",
            "regex": "AC[a-z0-9]{32}",
            "flags": "g"
        },
        {
            "name": "Twilio Auth Token",
            "regex": "(?:twilio[_\\-\\s]?auth[_\\-\\s]?token)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([a-z0-9]{32})",
            "flags": "gi"
        },
        {
            "name": "SendGrid API Key",
            "regex": "SG\\.[A-Za-z0-9_\\-]{22}\\.[A-Za-z0-9_\\-]{43}",
            "flags": "g"
        },
        {
            "name": "Mailgun API Key",
            "regex": "key-[0-9a-z]{32}",
            "flags": "g"
        },
        {
            "name": "Mailchimp API Key",
            "regex": "[0-9a-f]{32}-us[0-9]{1,2}",
            "flags": "g"
        },
        {
            "name": "JSON Web Token (JWT)",
            "regex": "eyJ[A-Za-z0-9_\\-]{10,}\\.eyJ[A-Za-z0-9_\\-]{10,}\\.[A-Za-z0-9_\\-]{10,}",
            "flags": "g"
        },
        {
            "name": "HTTP Basic Auth Header",
            "regex": "Authorization:\\s*Basic\\s+[A-Za-z0-9+/=]{8,}",
            "flags": "gi"
        },
        {
            "name": "HTTP Bearer Token Header",
            "regex": "Authorization:\\s*Bearer\\s+[A-Za-z0-9_.+/=\\-]{20,}",
            "flags": "gi"
        },
        {
            "name": "OAuth2 Client Secret",
            "regex": "(?:client[_\\-]?secret)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9_\\-]{20,})",
            "flags": "gi"
        },
        {
            "name": "RSA Private Key",
            "regex": "-----BEGIN RSA PRIVATE KEY-----",
            "flags": "g"
        },
        {
            "name": "EC Private Key",
            "regex": "-----BEGIN EC PRIVATE KEY-----",
            "flags": "g"
        },
        {
            "name": "OpenSSH Private Key",
            "regex": "-----BEGIN OPENSSH PRIVATE KEY-----",
            "flags": "g"
        },
        {
            "name": "DSA Private Key",
            "regex": "-----BEGIN DSA PRIVATE KEY-----",
            "flags": "g"
        },
        {
            "name": "PKCS#8 Private Key",
            "regex": "-----BEGIN PRIVATE KEY-----",
            "flags": "g"
        },
        {
            "name": "PGP Private Key Block",
            "regex": "-----BEGIN PGP PRIVATE KEY BLOCK-----",
            "flags": "g"
        },
        {
            "name": "MongoDB Connection String",
            "regex": "mongodb(?:\\+srv)?://[^:/@\\s]+:[^@\\s]+@[^/\\s\\\"\\']+",
            "flags": "g"
        },
        {
            "name": "PostgreSQL Connection String",
            "regex": "postgres(?:ql)?://[^:/@\\s]+:[^@\\s]+@[^/\\s\\\"\\']+",
            "flags": "g"
        },
        {
            "name": "Redis Connection URL",
            "regex": "redis://:[^@\\s]+@[^/\\s\\\"\\']+",
            "flags": "g"
        },
        {
            "name": "MySQL / MariaDB Connection String",
            "regex": "mysql(?:2)?://[^:/@\\s]+:[^@\\s]+@[^/\\s\\\"\\']+",
            "flags": "g"
        },
        {
            "name": "MSSQL Connection String",
            "regex": "(?:mssql|sqlserver)://[^:/@\\s]+:[^@\\s]+@[^/\\s\\\"\\']+",
            "flags": "gi"
        },
        {
            "name": "npm Access Token",
            "regex": "npm_[A-Za-z0-9]{36}",
            "flags": "g"
        },
        {
            "name": "PyPI API Token",
            "regex": "pypi-[A-Za-z0-9_\\-]{40,}",
            "flags": "g"
        },
        {
            "name": "RubyGems API Key",
            "regex": "rubygems_[A-Za-z0-9]{48}",
            "flags": "g"
        },
        {
            "name": "OpenAI API Key",
            "regex": "sk-[A-Za-z0-9]{48}",
            "flags": "g"
        },
        {
            "name": "OpenAI Project API Key",
            "regex": "sk-proj-[A-Za-z0-9_\\-]{86,}",
            "flags": "g"
        },
        {
            "name": "Anthropic API Key",
            "regex": "sk-ant-[A-Za-z0-9_\\-]{95,}",
            "flags": "g"
        },
        {
            "name": "HuggingFace API Token",
            "regex": "hf_[A-Za-z0-9]{34,}",
            "flags": "g"
        },
        {
            "name": "Replicate API Token",
            "regex": "r8_[A-Za-z0-9]{40}",
            "flags": "g"
        },
        {
            "name": "Shopify Admin API Access Token",
            "regex": "shpat_[A-Za-z0-9]{32}",
            "flags": "g"
        },
        {
            "name": "Shopify Custom App Access Token",
            "regex": "shpca_[A-Za-z0-9]{32}",
            "flags": "g"
        },
        {
            "name": "Shopify Shared Secret",
            "regex": "shpss_[A-Za-z0-9]{32}",
            "flags": "g"
        },
        {
            "name": "WooCommerce Consumer Secret",
            "regex": "cs_[A-Za-z0-9]{40}",
            "flags": "g"
        },
        {
            "name": "HashiCorp Vault Service Token",
            "regex": "hvs\\.[A-Za-z0-9_\\-]{90,}",
            "flags": "g"
        },
        {
            "name": "Doppler Personal Token",
            "regex": "dp\\.pt\\.[A-Za-z0-9]{43}",
            "flags": "g"
        },
        {
            "name": "Docker Hub Personal Access Token",
            "regex": "dckr_pat_[A-Za-z0-9_\\-]{27,}",
            "flags": "g"
        },
        {
            "name": "Heroku API Key",
            "regex": "(?:heroku[_\\-\\s]?api[_\\-\\s]?key)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})",
            "flags": "gi"
        },
        {
            "name": "Vercel API Token",
            "regex": "(?:vercel[_\\-\\s]?token)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9]{24,})",
            "flags": "gi"
        },
        {
            "name": "Netlify Access Token",
            "regex": "(?:netlify[_\\-\\s]?token)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9_\\-]{40,})",
            "flags": "gi"
        },
        {
            "name": "CircleCI Personal API Token",
            "regex": "(?:circle[_\\-]?ci[_\\-\\s]?token)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9]{40})",
            "flags": "gi"
        },
        {
            "name": "Travis CI API Token",
            "regex": "(?:travis[_\\-\\s]?token)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9_\\-]{22})",
            "flags": "gi"
        },
        {
            "name": "New Relic License Key",
            "regex": "NRAK-[A-Z0-9]{27}",
            "flags": "g"
        },
        {
            "name": "Datadog API Key",
            "regex": "(?:datadog[_\\-\\s]?api[_\\-\\s]?key)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([a-z0-9]{32})",
            "flags": "gi"
        },
        {
            "name": "Sentry DSN",
            "regex": "https://[a-z0-9]{32}@[a-z0-9.]+\\.ingest\\.sentry\\.io/[0-9]+",
            "flags": "g"
        },
        {
            "name": "Firebase Cloud Messaging Server Key",
            "regex": "AAAA[A-Za-z0-9_\\-]{7}:[A-Za-z0-9_\\-]{140}",
            "flags": "g"
        },
        {
            "name": "Generic API Key Assignment",
            "regex": "(?:api[_\\-]?key|apikey)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9_\\-]{20,})",
            "flags": "gi"
        },
        {
            "name": "Generic Secret Key Assignment",
            "regex": "(?:secret[_\\-]?key|secret)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9_\\-!@#$%^&*]{16,})",
            "flags": "gi"
        },
        {
            "name": "Generic Password Assignment",
            "regex": "(?:password|passwd|pwd)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*(?![\\*\\s\\\"\\'])([^\\s\\\"\\']{8,})",
            "flags": "gi"
        },
        {
            "name": "Generic Auth / Access Token Assignment",
            "regex": "(?:auth[_\\-]?token|access[_\\-]?token|bearer[_\\-]?token)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9_\\-.]{20,})",
            "flags": "gi"
        },
        {
            "name": "High-Entropy Hex Secret",
            "regex": "(?:secret|key|token|password|passwd|credential)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([a-f0-9]{32,})",
            "flags": "gi"
        },
        {
            "name": "High-Entropy Base64 Secret",
            "regex": "(?:secret|key|token)[\\\"\\'\\s]*[=:][\\\"\\'\\s]*([A-Za-z0-9+/]{40,}={0,2})",
            "flags": "gi"
        }
    ]
}
